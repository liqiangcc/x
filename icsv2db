

db_file=$2
table_name=$3
csv_file=$1
n=$(head -1 $csv_file | tr ',' '\n' | wc -l)

bash createTable.sh $db_file $table_name $n

sqlite3 "$db_file" <<EOF
.mode csv
.import  $csv_file $table_name
EOF

c=$(sqlite3 $db_file "select count(*) from $table_name")
echo "import csv line: $(cat $csv_file | wc -l), $table_name: $c"

