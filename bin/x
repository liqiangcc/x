#!/usr/bin/env node

const fs = require("node:fs/promises");
const os = require("node:os");
const path = require("node:path");
const { execFile, spawn } = require("node:child_process");
const { promisify } = require("node:util");
const {
  AWS_ACCESS_KEY_SECRET,
  AWS_REGION_VARIABLE,
  AWS_SECRET_KEY_SECRET,
  awsProfileEnv,
  buildGithubSecretSetArgs,
  buildGithubVariableSetArgs,
  getAwsCallerIdentity,
  getToolVersion,
  normalizeAwsOptions,
  readAwsProfileCredentials,
  resolveGitHubRepo,
  sanitizeError,
  summarizeCredentials,
} = require("../src/aws/maintenance");
const { existingPathspecs, stagedFiles } = require("../src/core/git");
const {
  applyProgressResults,
  calculateMaxChainDepth,
  initializeProgress,
  normalizeJobId,
  normalizeProgress,
  selectProgressBatch,
  uniqueCodes,
} = require("../src/jobs/progress");
const { inferSecid } = require("../src/core/secid");

const execFileAsync = promisify(execFile);
const ROOT = path.resolve(__dirname, "..");
const DEFAULT_POOL_DIR = path.join(ROOT, "data", "pool");
const DEFAULT_KLINE_DIR = path.join(ROOT, "data", "kline");
const DEFAULT_RUNS_DIR = path.join(ROOT, "runs");
const DEFAULT_UNIVERSE_DIR = path.join(ROOT, "data", "universe");
const DEFAULT_JOBS_DIR = path.join(ROOT, "data", "jobs");

function rel(filePath) {
  return path.relative(ROOT, filePath).replaceAll(path.sep, "/");
}

function rootPath(filePath) {
  return path.isAbsolute(filePath) ? filePath : path.join(ROOT, filePath);
}

