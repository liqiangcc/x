function normalizeDate(input) {
  const digits = String(input).replace(/-/g, "");
  if (!/^\d{8}$/.test(digits)) {
    throw new Error(`Invalid date: ${input}`);
  }
  return digits;
}

function parseOptions(argv, defaults = {}) {
  const options = { _: [], ...defaults };
  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    if (!arg.startsWith("--")) {
      options._.push(arg);
      continue;
    }

    const key = arg.slice(2).replace(/-([a-z])/g, (_, char) => char.toUpperCase());
    if (["latest", "commit", "force", "forcePool", "forceUniverse", "json", "allowPartial"].includes(key)) {
      options[key] = true;
      continue;
    }

    const nextArg = argv[index + 1];
    if (!nextArg) {
      throw new Error(`Missing value for ${arg}`);
    }
    options[key] = nextArg;
    index += 1;
  }
  return options;
}

async function runNode(scriptPath, args, options = {}) {
  if (options.streamOutput) {
    return runNodeStreaming(scriptPath, args, options);
  }
  return execFileAsync("node", [path.join(ROOT, scriptPath), ...args], {
    cwd: ROOT,
    env: options.env ?? process.env,
    maxBuffer: options.maxBuffer ?? 50 * 1024 * 1024,
  });
}

function runNodeStreaming(scriptPath, args, options = {}) {
  return new Promise((resolve, reject) => {
    const child = spawn(process.execPath, [path.join(ROOT, scriptPath), ...args], {
      cwd: ROOT,
      env: options.env ?? process.env,
      stdio: ["ignore", "pipe", "pipe"],
    });
    let stdout = "";
    let stderr = "";

    child.stdout.on("data", (chunk) => {
      const text = chunk.toString();
      stdout += text;
      if (options.echoStdout !== false) {
        process.stdout.write(text);
      }
    });
    child.stderr.on("data", (chunk) => {
      const text = chunk.toString();
      stderr += text;
      if (options.echoStderr !== false) {
        process.stderr.write(text);
      }
    });
    child.on("error", reject);
    child.on("close", (code) => {
      const result = { stdout, stderr, streamed: true };
      if (code === 0) {
        resolve(result);
        return;
      }
      const error = new Error(`${scriptPath} failed with exit code ${code ?? 1}`);
      error.code = code ?? 1;
      error.stdout = stdout;
      error.stderr = stderr || error.message;
      error.streamed = true;
      reject(error);
    });
  });
}

async function runNodeAllowFailure(scriptPath, args, options = {}) {
  try {
    const result = await runNode(scriptPath, args, options);
    return { ...result, exitCode: 0 };
  } catch (error) {
    return {
      stdout: error.stdout ?? "",
      stderr: error.stderr ?? error.message,
      streamed: Boolean(error.streamed),
      exitCode: typeof error.code === "number" ? error.code : 1,
    };
  }
}

function writeProcessResult(result) {
  if (result?.streamed) {
    return;
  }
  process.stdout.write(result?.stdout ?? "");
  process.stderr.write(result?.stderr ?? "");
}

function runCommandWithInput(command, args, input, options = {}) {
  return new Promise((resolve, reject) => {
    const child = spawn(command, args, {
      cwd: options.cwd ?? ROOT,
      env: options.env ?? process.env,
      stdio: ["pipe", "pipe", "pipe"],
    });
    let stdout = "";
    let stderr = "";

    child.stdout.on("data", (chunk) => {
      stdout += chunk.toString();
    });
    child.stderr.on("data", (chunk) => {
      stderr += chunk.toString();
    });
    child.on("error", reject);
    child.on("close", (code) => {
      if (code === 0) {
        resolve({ stdout, stderr });
        return;
      }

      const error = new Error(`${command} ${args.join(" ")} failed with exit code ${code ?? 1}`);
      error.code = code ?? 1;
      error.stdout = stdout;
      error.stderr = stderr;
      reject(error);
    });

    child.stdin.end(input);
  });
}

async function readJson(filePath, fallback = null) {
  try {
    return JSON.parse(await fs.readFile(filePath, "utf8"));
  } catch (error) {
    if (fallback !== null && error.code === "ENOENT") {
      return fallback;
    }
    throw error;
  }
}

async function writeJson(filePath, payload) {
  await fs.mkdir(path.dirname(filePath), { recursive: true });
  await fs.writeFile(filePath, `${JSON.stringify(payload, null, 2)}\n`, "utf8");
}

function utcCompactTime(date = new Date()) {
  const hours = String(date.getUTCHours()).padStart(2, "0");
  const minutes = String(date.getUTCMinutes()).padStart(2, "0");
  const seconds = String(date.getUTCSeconds()).padStart(2, "0");
  return `${hours}${minutes}${seconds}`;
}

function isoNow() {
  return new Date().toISOString().replace(/\.\d{3}Z$/, "Z");
}

function runIdFor(date, period, now = new Date()) {
  return `${date}T${utcCompactTime(now)}Z_${period}`;
}

async function commandDoctor() {
  const checks = [
    ["node", ["--version"]],
    ["git", ["--version"]],
  ];

  let failed = 0;
  for (const [command, args] of checks) {
    try {
      const { stdout } = await execFileAsync(command, args, { cwd: ROOT });
      console.log(`${command}: ${(stdout.split("\n")[0] || "ok").trim()}`);
    } catch (error) {
      failed += 1;
      console.error(`${command}: missing or failed (${error.message})`);
    }
  }

  const major = Number(process.versions.node.split(".")[0]);
  if (major < 22) {
    console.error(`node: v${process.versions.node} detected; Node 22+ is required for SQLite commands.`);
  }

  if (failed > 0) {
    process.exitCode = 1;
  }
}

async function runAwsKlinePreflight({ profile, preflightRegion, lambdaName }) {
  const args = [
    "600519",
    "--period",
    "daily",
    "--engine",
    "aws",
    "--lambda-name",
    lambdaName,
  ];
  if (preflightRegion) {
    args.push("--aws-region", preflightRegion);
  }

  const result = await runNodeAllowFailure(
    "fetch/fetch_kline.js",
    args,
    {
      env: awsProfileEnv(profile, {
        ...process.env,
        NODE_NO_WARNINGS: "1",
      }),
    }
  );

  if (result.exitCode !== 0) {
    return {
      ok: false,
      error: sanitizeError({ stderr: result.stderr || result.stdout || "AWS kline preflight failed." }),
    };
  }

  try {
    const payload = JSON.parse(result.stdout);
    const klines = Array.isArray(payload?.data?.klines)
      ? payload.data.klines
      : Array.isArray(payload?.klines)
        ? payload.klines
        : [];
    return {
      ok: true,
      code: payload?.data?.code ?? payload?.code ?? "600519",
      points: klines.length,
      source_engine: payload?.source_engine ?? null,
      source_region: payload?.source_region ?? null,
    };
  } catch (error) {
    return {
      ok: false,
      error: `Failed to parse AWS kline preflight output: ${error.message}`,
    };
  }
}

async function requireTool(command, args) {
  const tool = await getToolVersion(command, args, execFileAsync);
  if (!tool.ok) {
    throw new Error(`${command} CLI is not available: ${tool.error}`);
  }
  return tool;
}

async function commandAwsStatus(rawOptions) {
  const options = normalizeAwsOptions(rawOptions);
  const summary = {
    profile: options.profile,
    region: options.region,
    preflight_region: options.preflightRegion ?? "config/default",
    lambda_name: options.lambdaName,
    tools: {
      aws: await getToolVersion("aws", ["--version"], execFileAsync),
      gh: await getToolVersion("gh", ["--version"], execFileAsync),
    },
    credentials: null,
    identity: null,
    lambda_preflight: null,
    status: "ok",
  };

  let credentialsOk = false;
  if (summary.tools.aws.ok) {
    try {
      const credentials = await readAwsProfileCredentials({
        profile: options.profile,
        execFileAsync,
      });
      summary.credentials = {
        ok: true,
        ...summarizeCredentials(credentials),
      };
      credentialsOk = true;
    } catch (error) {
      summary.credentials = {
        ok: false,
        error: sanitizeError(error),
      };
    }

    try {
      summary.identity = {
        ok: true,
        ...(await getAwsCallerIdentity({
          profile: options.profile,
          execFileAsync,
        })),
      };
    } catch (error) {
      summary.identity = {
        ok: false,
        error: sanitizeError(error),
      };
    }
  } else {
    summary.credentials = {
      ok: false,
      error: "aws CLI is unavailable.",
    };
    summary.identity = {
      ok: false,
      error: "aws CLI is unavailable.",
    };
  }

  if (credentialsOk) {
    summary.lambda_preflight = await runAwsKlinePreflight(options);
  } else {
    summary.lambda_preflight = {
      ok: false,
      error: "Static AWS profile credentials are required before Lambda preflight.",
    };
  }

  const failed =
    !summary.tools.aws.ok ||
    !summary.tools.gh.ok ||
    !summary.credentials.ok ||
    !summary.identity.ok ||
    !summary.lambda_preflight.ok;
  if (failed) {
    summary.status = "failed";
    process.exitCode = 1;
  }

  printJson(summary);
}

async function commandAwsSyncGithubSecrets(rawOptions) {
  const options = normalizeAwsOptions(rawOptions);
  const awsTool = await requireTool("aws", ["--version"]);
  const ghTool = await requireTool("gh", ["--version"]);
  const credentials = await readAwsProfileCredentials({
    profile: options.profile,
    execFileAsync,
  });
  const identity = await getAwsCallerIdentity({
    profile: options.profile,
    execFileAsync,
  });
  const preflight = await runAwsKlinePreflight(options);
  if (!preflight.ok) {
    throw new Error(`AWS kline preflight failed: ${preflight.error}`);
  }

  const repo = await resolveGitHubRepo({
    repo: rawOptions.repo,
    execFileAsync,
    cwd: ROOT,
  });
  await runCommandWithInput(
    "gh",
    buildGithubSecretSetArgs(AWS_ACCESS_KEY_SECRET, repo),
    `${credentials.accessKeyId}\n`
  );
  await runCommandWithInput(
    "gh",
    buildGithubSecretSetArgs(AWS_SECRET_KEY_SECRET, repo),
    `${credentials.secretAccessKey}\n`
  );
  await execFileAsync("gh", buildGithubVariableSetArgs(AWS_REGION_VARIABLE, options.region, repo), {
    cwd: ROOT,
    maxBuffer: 20 * 1024 * 1024,
  });

  printJson({
    status: "ok",
    profile: options.profile,
    region: options.region,
    preflight_region: options.preflightRegion ?? "config/default",
    lambda_name: options.lambdaName,
    repo,
    tools: {
      aws: awsTool.version,
      gh: ghTool.version,
    },
    identity,
    lambda_preflight: preflight,
    github: {
      secrets: [AWS_ACCESS_KEY_SECRET, AWS_SECRET_KEY_SECRET],
      variables: [AWS_REGION_VARIABLE],
    },
  });
}

function periodToKlt(period = "daily") {
  if (period === "daily") {
    return 101;
  }
  if (period === "yearly") {
    return 106;
  }
  throw new Error(`Invalid period: ${period}`);
}

function requiredEnv(name) {
  const value = String(process.env[name] ?? "").trim();
  if (!value) {
    throw new Error(`${name} is required.`);
  }
  return value;
}

function appendUrlPath(baseUrl, pathname) {
  return `${String(baseUrl).replace(/\/+$/, "")}${pathname}`;
}

async function postRouterJson(pathname, body) {
  const routerUrl = requiredEnv("AWS_ROUTER_URL");
  const routerToken = requiredEnv("AWS_ROUTER_TOKEN");
  const response = await fetch(appendUrlPath(routerUrl, pathname), {
    method: "POST",
    headers: {
      "content-type": "application/json",
      "x-router-token": routerToken,
    },
    body: JSON.stringify(body),
  });
  const rawText = await response.text();
  let payload;
  try {
    payload = rawText ? JSON.parse(rawText) : {};
  } catch (error) {
    throw new Error(`Failed to parse Router response: ${error.message}`);
  }
  if (!response.ok || payload?.ok === false) {
    throw new Error(`Router returned statusCode ${response.status}: ${payload?.error ?? rawText}`);
  }
  return payload;
}

async function commandAwsProbeRouter(rawOptions) {
  if (!rawOptions.secid) {
    throw new Error("aws probe-router requires --secid <secid_or_code>.");
  }
  const payload = await postRouterJson("/probe", {
    region: rawOptions.targetRegion ?? "all",
    secid: inferSecid(rawOptions.secid),
    klt: periodToKlt(rawOptions.period ?? "daily"),
    lmt: rawOptions.lmt ? Number(rawOptions.lmt) : 1,
    end: rawOptions.end ?? "20991231",
  });
  printJson(payload);
}

async function commandAwsLatency(rawOptions) {
  const configFile = rawOptions.config ? rootPath(rawOptions.config) : path.join(ROOT, "config", "kline.json");
  const config = await readJson(configFile, {});
  const options = normalizeLatencyOptions(rawOptions, config);
  const report = await runLatencyBenchmark(options);
  const output = `${JSON.stringify(report, null, 2)}\n`;

  if (rawOptions.output) {
    const outputPath = rootPath(rawOptions.output);
    await fs.mkdir(path.dirname(outputPath), { recursive: true });
    await fs.writeFile(outputPath, output, "utf8");
  }

  if (rawOptions.json) {
    process.stdout.write(output);
    return;
  }

  process.stdout.write(formatLatencyReport(report));
}

async function commandAws(argv) {
  const subcommand = argv[0];
  const options = parseOptions(argv.slice(1));

  if (subcommand === "status") {
    await commandAwsStatus(options);
    return;
  }

  if (subcommand === "sync-github-secrets") {
    await commandAwsSyncGithubSecrets(options);
    return;
  }

  if (subcommand === "probe-router") {
    await commandAwsProbeRouter(options);
    return;
  }

  if (subcommand === "latency") {
    await commandAwsLatency(options);
    return;
  }

  throw new Error(`Unknown aws command: ${subcommand ?? ""}`);
}

async function commandKlineFetch(argv) {
  const options = parseOptions(argv, { period: "daily", engine: "auto" });
  const input = options._[0];
  if (!input) {
    throw new Error("kline fetch requires <code_or_secid>");
  }

  const args = [input, "--period", options.period, "--engine", options.engine];
  if (options.awsRegion) {
    args.push("--aws-region", options.awsRegion);
  }
  if (options.huaweicloudRegion) {
    args.push("--huaweicloud-region", options.huaweicloudRegion);
  }
  if (options.huaweicloudRegionStartIndex) {
    args.push("--huaweicloud-region-start-index", String(options.huaweicloudRegionStartIndex));
  }
  if (options.huaweicloudTargets) {
    args.push("--huaweicloud-targets", options.huaweicloudTargets);
  }
  if (options.lambdaName) {
    args.push("--lambda-name", options.lambdaName);
  }
  if (options.config) {
    args.push("--config", options.config);
  }
  if (options.output) {
    args.push("--output", options.output);
  }

  const { stdout, stderr } = await runNode("fetch/fetch_kline.js", args);
  process.stdout.write(stdout);
  process.stderr.write(stderr);
}

function appendKlineSyncOptions(args, options, { includeOutputDir = true } = {}) {
  if (options.limit) {
    args.push("--limit", String(options.limit));
  }
  if (options.batchSize) {
    args.push("--batch-size", String(options.batchSize));
  }
  if (options.offset) {
    args.push("--offset", String(options.offset));
  }
  if (includeOutputDir && options.outputDir) {
    args.push("--output-dir", options.outputDir);
  }
  if (options.force) {
    args.push("--force");
  }
  if (options.concurrency) {
    args.push("--concurrency", String(options.concurrency));
  }
  if (options.retryAttempts) {
    args.push("--retry-attempts", String(options.retryAttempts));
  }
  if (options.retryDelayMs) {
    args.push("--retry-delay-ms", String(options.retryDelayMs));
  }
  if (options.retryConcurrency) {
    args.push("--retry-concurrency", String(options.retryConcurrency));
  }
  if (options.awsRegion) {
    args.push("--aws-region", options.awsRegion);
  }
  if (options.huaweicloudRegion) {
    args.push("--huaweicloud-region", options.huaweicloudRegion);
  }
  if (options.huaweicloudRegionStartIndex) {
    args.push("--huaweicloud-region-start-index", String(options.huaweicloudRegionStartIndex));
  }
  if (options.huaweicloudTargets) {
    args.push("--huaweicloud-targets", options.huaweicloudTargets);
  }
  if (options.lambdaName) {
    args.push("--lambda-name", options.lambdaName);
  }
  if (options.config) {
    args.push("--config", options.config);
  }
  if (options.minSuccessRate) {
    args.push("--min-success-rate", String(options.minSuccessRate));
  }
  if (options.expectedLatestDate) {
    args.push("--expected-latest-date", String(options.expectedLatestDate));
  }
  if (options.freshnessCodes) {
    args.push("--freshness-codes", String(options.freshnessCodes));
  }
}

async function commandPoolPull(argv) {
  const options = parseOptions(argv, { engine: "curl", outputDir: "data/pool" });
  const args = [];

  if (options.date) {
    args.push(normalizeDate(options.date));
  } else if (options._[0]) {
    args.push(normalizeDate(options._[0]));
  } else if (options.latest) {
    args.push("--days", "0");
  }

  if (options.rangeDays) {
    args.push("--range-days", String(options.rangeDays));
  }
  if (options.engine) {
    args.push("--engine", options.engine);
  }
  args.push("--output-dir", options.outputDir);

  const { stdout, stderr } = await runNode("fetch/pull_pool_task.js", args);
  process.stdout.write(stdout);
  process.stderr.write(stderr);
}

async function commandStocks(argv) {
  const subcommand = argv[0];
  if (subcommand !== "fetch") {
    throw new Error(`Unknown stocks command: ${subcommand ?? ""}`);
  }

  const options = parseOptions(argv.slice(1), {
    market: "hs-a",
    outputDir: rel(DEFAULT_UNIVERSE_DIR),
  });
  const args = ["--market", options.market, "--output-dir", options.outputDir];

  if (options.date && options.latest) {
    throw new Error("--date and --latest cannot be used together.");
  } else if (options.date) {
    args.push("--date", normalizeDate(options.date));
  } else {
    args.push("--latest");
  }
  if (options.pageSize) {
    args.push("--page-size", String(options.pageSize));
  }

  const { stdout, stderr } = await runNode("fetch/fetch_market_stocks.js", args);
  process.stdout.write(stdout);
  process.stderr.write(stderr);
}

async function commandCodesBuild(argv) {
  const options = parseOptions(argv);
  const inputPath = options._[0];
  if (!inputPath) {
    throw new Error("codes build requires <pool_dir>");
  }

  const args = [inputPath, "--codes-only"];
  if (options.output) {
    args.push("--output", options.output);
  }
  const { stdout, stderr } = await runNode("utils/parse_pool_json.js", args);
  process.stdout.write(stdout);
  process.stderr.write(stderr);
}

async function commandKlineSync(argv) {
  const options = parseOptions(argv, { period: "daily", engine: "auto" });
  const inputPath = options._[0];
  if (!inputPath) {
    throw new Error("kline sync requires <input_dir|codes.json>");
  }

  const args = [inputPath, "--period", options.period, "--engine", options.engine];
  appendKlineSyncOptions(args, options);
  const { stdout, stderr } = await runNode("fetch/query_pool_klines.js", args);
  process.stdout.write(stdout);
  process.stderr.write(stderr);
}

function extractRetryCodes(payload) {
  if (Array.isArray(payload?.codes)) {
    return [...new Set(payload.codes.map(String).filter(Boolean))].sort();
  }

  if (payload?.files && typeof payload.files === "object") {
    return Object.entries(payload.files)
      .filter(([, item]) => item?.status === "failed")
      .map(([code, item]) => item?.code ?? code)
      .filter(Boolean)
      .sort();
  }

  if (Array.isArray(payload?.items)) {
    return [...new Set(payload.items
      .map((item) => item?.code ?? item?.target)
      .filter(Boolean)
      .map((value) => String(value).includes(".") ? String(value).split(".")[1] : String(value))
    )].sort();
  }

  return [];
}

function inferKlineOutputDirFromSummary(summaryPath, period) {
  const resolved = path.resolve(summaryPath);
  if (path.basename(resolved) === `summary.${period}.json`) {
    return path.dirname(path.dirname(resolved));
  }
  return "data/kline";
}

async function commandKlineRetry(argv) {
  const options = parseOptions(argv, { engine: "aws" });
  const inputPath = options._[0];
  if (!inputPath) {
    throw new Error("kline retry requires <summary.json|failures.json>");
  }

  const payload = await readJson(path.resolve(inputPath));
  const codes = extractRetryCodes(payload);
  if (codes.length === 0) {
    throw new Error("No failed kline codes found to retry.");
  }

  const itemPeriod = Array.isArray(payload?.items)
    ? payload.items.find((item) => item?.period)?.period
    : null;
  const period = options.period ?? payload.period ?? itemPeriod ?? "daily";
  const outputDir = options.outputDir ?? inferKlineOutputDirFromSummary(inputPath, period);
  const tempDir = await fs.mkdtemp(path.join(os.tmpdir(), "x-kline-retry-"));
  const codesPath = path.join(tempDir, "codes.json");
  await writeJson(codesPath, { codes });

  const args = [
    codesPath,
    "--period",
    period,
    "--engine",
    options.engine,
    "--output-dir",
    outputDir,
  ];
  appendKlineSyncOptions(args, {
    ...options,
    concurrency: options.concurrency ?? 1,
    limit: null,
    outputDir: null,
    period,
    retryAttempts: options.retryAttempts ?? 3,
    retryConcurrency: options.retryConcurrency ?? 1,
  }, { includeOutputDir: false });

  const result = await runNodeAllowFailure("fetch/query_pool_klines.js", args);
  process.stdout.write(result.stdout);
  process.stderr.write(result.stderr);
  await fs.rm(tempDir, { recursive: true, force: true });
  if (result.exitCode !== 0) {
    process.exitCode = result.exitCode;
  }
}

async function commandKlineValidate(argv) {
  const options = parseOptions(argv);
  const targetPath = options._[0] ?? "data/kline";
  const args = [targetPath];
  if (options.period) {
    args.push("--period", options.period);
  }
  if (options.json) {
    args.push("--json");
  }

  const result = await runNodeAllowFailure("fetch/check_kline_empty.js", args);
  process.stdout.write(result.stdout);
  process.stderr.write(result.stderr);
  if (result.exitCode !== 0) {
    process.exitCode = result.exitCode;
  }
}

function extractKlineFailures(summary, period) {
  const files = summary?.files && typeof summary.files === "object" ? summary.files : {};
  return Object.entries(files)
    .filter(([, item]) => item?.status === "failed")
    .map(([code, item]) => ({
      target: item.secid ?? code,
      code,
      type: "kline",
      period,
      reason: item.error ?? "unknown error",
      retry_count: 0,
    }));
}

async function buildQuality(runId, validateResult, period) {
  let parsed;
  try {
    parsed = JSON.parse(validateResult.stdout);
  } catch {
    parsed = {
      target_path: rel(path.join(DEFAULT_KLINE_DIR, period)),
      total_files: 0,
      issue_count: 1,
      status: "failed",
      issues: [
        {
          issue: "quality_parse_error",
          error: validateResult.stderr || "failed to parse validator output",
        },
      ],
    };
  }

  return {
    run_id: runId,
    target: parsed.target_path,
    period,
    total_files: parsed.total_files ?? 0,
    issue_count: parsed.issue_count ?? parsed.empty_count ?? 0,
    status: parsed.status ?? ((parsed.issue_count ?? parsed.empty_count ?? 0) > 0 ? "failed" : "ok"),
    issues: parsed.issues ?? [],
  };
}

async function cleanupInvalidKlineFiles(period) {
  let summary;
  try {
    summary = await validateKlinePath({
      targetPath: DEFAULT_KLINE_DIR,
      period,
    });
  } catch (error) {
    if (error?.code !== "ENOENT") {
      throw error;
    }
    return {
      target_path: path.join(DEFAULT_KLINE_DIR, period),
      total_files: 0,
      issue_count: 0,
      status: "ok",
      issues: [],
      removed_codes: [],
    };
  }
  const issues = Array.isArray(summary.issues) ? summary.issues : [];
  const removedCodes = [];

  for (const issue of issues) {
    if (!issue?.file) {
      continue;
    }
    await fs.rm(issue.file, { force: true });
    if (issue.code) {
      removedCodes.push(String(issue.code));
    }
  }

  return {
    ...summary,
    removed_codes: uniqueCodes(removedCodes),
  };
}

function formatExpectedLatestDate(date) {
  const normalized = normalizeDate(date);
  return `${normalized.slice(0, 4)}-${normalized.slice(4, 6)}-${normalized.slice(6, 8)}`;
}

function latestKlineDate(payload) {
  const klines = getKlines(payload);
  if (!Array.isArray(klines.value) || klines.value.length === 0) {
    return null;
  }

  for (let index = klines.value.length - 1; index >= 0; index -= 1) {
    const row = klines.value[index];
    if (typeof row !== "string") {
      continue;
    }
    const date = row.split(",")[0];
    if (/^\d{4}-\d{2}-\d{2}$/.test(date)) {
      return date;
    }
  }

  return null;
}

function shardedKlinePath(period, code) {
  return path.join(DEFAULT_KLINE_DIR, period, code.slice(0, 3), `${code}.json`);
}

function legacyKlinePath(period, code) {
  return path.join(DEFAULT_KLINE_DIR, period, `${code}.json`);
}

async function readFreshnessCodesFromMarketUniverse(inputDir) {
  try {
    const payload = await readJson(path.join(inputDir, "stocks.json"));
    const stocks = Array.isArray(payload?.stocks) ? payload.stocks : [];
    const hasQuoteMetadata = stocks.some((stock) => typeof stock?.quote_available === "boolean");
    if (!hasQuoteMetadata) {
      return null;
    }
    return uniqueCodes(
      stocks
        .filter((stock) => stock?.quote_available === true)
        .map((stock) => stock.code)
    );
  } catch {
    return null;
  }
}

async function buildKlineFreshnessContext({ date, inputDir, options, runDir }) {
  if (!["daily", "yearly"].includes(options.period)) {
    return null;
  }

  const expectedLatestDate = formatExpectedLatestDate(date);
  const source = options.universe === "market" ? "market_quote_available" : "pool_codes";
  const codes = options.universe === "market"
    ? await readFreshnessCodesFromMarketUniverse(inputDir)
    : await loadCodesJson(inputDir);

  if (!codes || codes.length === 0) {
    return {
      codes: new Set(),
      codesPath: null,
      expectedLatestDate,
      source,
    };
  }

  const codesPath = path.join(runDir, "freshness.codes.json");
  await writeJson(codesPath, {
    date,
    expected_latest_date: expectedLatestDate,
    period: options.period,
    source,
    total_codes: codes.length,
    codes,
  });

  return {
    codes: new Set(codes),
    codesPath,
    expectedLatestDate,
    source,
  };
}

async function findStaleKlineCodes({ expectedLatestDate, freshnessCodes, period }) {
  if (!["daily", "yearly"].includes(period) || !expectedLatestDate || !freshnessCodes || freshnessCodes.size === 0) {
    return [];
  }

  const staleCodes = [];
  for (const code of freshnessCodes) {
    let filePath = shardedKlinePath(period, code);
    try {
      await fs.access(filePath);
    } catch {
      filePath = legacyKlinePath(period, code);
    }

    let payload;
    try {
      payload = await readJson(filePath);
    } catch {
      continue;
    }

    const latestDate = latestKlineDate(payload);
    if (!latestDate || latestDate < expectedLatestDate) {
      staleCodes.push(code);
    }
  }

  return uniqueCodes(staleCodes);
}

function parsePositiveIntegerOption(value, fallback) {
  const number = Number(value);
  return Number.isInteger(number) && number > 0 ? number : fallback;
}

function parseNonNegativeIntegerOption(value, fallback) {
  const number = Number(value);
  return Number.isInteger(number) && number >= 0 ? number : fallback;
}

function defaultDailyBatchSize(period) {
  return 300;
}

async function loadCodesJson(inputDir) {
  const payload = await readJson(path.join(inputDir, "codes.json"));
  if (!Array.isArray(payload?.codes)) {
    throw new Error(`Missing codes array: ${rel(path.join(inputDir, "codes.json"))}`);
  }
  return uniqueCodes(payload.codes);
}

function defaultDailyJobId({ date, market, period, universe }) {
  const parts = [date, period, universe];
  if (universe === "market") {
    parts.push(market);
  }
  return parts.join("-");
}

function dailyJobIdForOptions(options, date) {
  let fallbackJobId = defaultDailyJobId({
    date,
    market: options.universe === "market" ? options.market : null,
    period: options.period,
    universe: options.universe,
  });
  if (options.limit) {
    fallbackJobId = `${fallbackJobId}-limit-${options.limit}`;
  }
  if (options.offset) {
    fallbackJobId = `${fallbackJobId}-offset-${options.offset}`;
  }
  return normalizeJobId(options.jobId, fallbackJobId);
}

function progressPathFor(date, period, jobId) {
  return path.join(DEFAULT_JOBS_DIR, date, period, jobId, "progress.json");
}

function parseKlineSummaryPath(stdout, period) {
  const expected = `summary.${period}.json`;
  const line = String(stdout ?? "")
    .split(/\r?\n/)
    .map((item) => item.trim())
    .filter(Boolean)
    .reverse()
    .find((item) => item.endsWith(expected));
  return line ? rootPath(line) : null;
}

async function prepareDailyJobProgress(options, { date, inputDir, preselectFailedCodes = [] }) {
  if ((options.jobMode ?? "single") !== "batch") {
    return null;
  }

  const batchSize = parsePositiveIntegerOption(options.batchSize, defaultDailyBatchSize(options.period));
  const chainDepth = parseNonNegativeIntegerOption(options.chainDepth, 0);
  const jobId = dailyJobIdForOptions(options, date);
  const progressPath = progressPathFor(date, options.period, jobId);
  const existingProgress = await readExistingJson(progressPath);
  let progress;

  if (existingProgress) {
    progress = normalizeProgress(existingProgress);
    progress.batch_size = batchSize;
    progress.chain_depth = chainDepth;
    if (options.maxChainDepth) {
      progress.max_chain_depth = parsePositiveIntegerOption(options.maxChainDepth, progress.max_chain_depth);
    }
    if (preselectFailedCodes.length > 0) {
      progress = markProgressCodesFailed(progress, preselectFailedCodes);
    }
  } else {
    let codes = await loadCodesJson(inputDir);
    const offset = parseNonNegativeIntegerOption(options.offset, 0);
    const limit = options.limit ? parsePositiveIntegerOption(options.limit, null) : null;
    codes = codes.slice(offset);
    if (limit !== null) {
      codes = codes.slice(0, limit);
    }
    progress = initializeProgress({
      batchSize,
      chainDepth,
      codes,
      date,
      jobId,
      market: options.universe === "market" ? options.market : null,
      maxChainDepth: options.maxChainDepth
        ? parsePositiveIntegerOption(options.maxChainDepth, null)
        : calculateMaxChainDepth(codes.length, batchSize),
      period: options.period,
      universe: options.universe,
    });
  }

  const selection = selectProgressBatch(progress);
  progress.last_batch_codes = selection.codes;
  progress.last_batch_source = selection.source;
  progress.updated_at = isoNow();
  await writeJson(progressPath, progress);

  const batchCodesPath = path.join(path.dirname(progressPath), "current.codes.json");
  await writeJson(batchCodesPath, {
    job_id: jobId,
    date,
    period: options.period,
    chain_depth: chainDepth,
    batch_size: progress.batch_size,
    selection_source: selection.source,
    codes: selection.codes,
  });

  return {
    batchCodesPath,
    chainDepth,
    jobId,
    progress,
    progressPath,
    selection,
  };
}

async function commandDaily(argv) {
  const options = parseOptions(argv, {
    engine: "auto",
    market: "hs-a",
    period: "daily",
    poolEngine: "curl",
    outputDir: "data/pool",
    universe: "market",
    universeDir: rel(DEFAULT_UNIVERSE_DIR),
  });
  const startedAt = isoNow();
  const streamOutput = isStageLogEnabled();

  if (!options.date && !options.latest) {
    options.latest = true;
  }
  if (!["market", "pool"].includes(options.universe)) {
    throw new Error(`Invalid universe: ${options.universe}`);
  }
  if (!["batch", "single"].includes(options.jobMode ?? "single")) {
    throw new Error(`Invalid job mode: ${options.jobMode}`);
  }
  if (!options.concurrency) {
    options.concurrency = "4";
  }
  stageLog("start", "daily_start", {
    date: options.date ?? null,
    latest: Boolean(options.latest),
    period: options.period,
    engine: options.engine,
    universe: options.universe,
    job_mode: options.jobMode ?? "single",
    batch_size: options.batchSize ?? null,
    concurrency: options.concurrency,
    force: Boolean(options.force),
  });

  let date = options.date ? normalizeDate(options.date) : null;
  let poolResult;

  poolResult = await withStage("pool_snapshot", {
    date,
    latest: Boolean(options.latest),
    output_dir: options.outputDir,
    force_pool: Boolean(options.forcePool),
  }, async () => {
    if (date && !options.forcePool && (await hasCompletePoolSnapshot(date, options.outputDir))) {
      return {
        stdout: `Using existing pool snapshot: ${rel(path.join(ROOT, options.outputDir, date))}\n`,
        stderr: "",
        exitCode: 0,
      };
    }
    const poolArgs = ["--output-dir", options.outputDir, "--engine", options.poolEngine];
    if (date) {
      poolArgs.unshift(date);
    } else {
      poolArgs.unshift("--days", "0");
    }

    return runNodeAllowFailure("fetch/pull_pool_task.js", poolArgs, { streamOutput });
  });
  writeProcessResult(poolResult);
  stageLog("end", "pool_snapshot_result", {
    exit_code: poolResult.exitCode,
    stdout_bytes: poolResult.stdout.length,
    stderr_bytes: poolResult.stderr.length,
  });

  const poolSummaryPath = path.join(ROOT, options.outputDir, "summary.json");
  const poolSummary = await readJson(poolSummaryPath, {});
  if (!date && poolResult.exitCode !== 0) {
    throw new Error("Failed to resolve latest pool date.");
  }
  date = normalizeDate(date ?? poolSummary.requested_date);
  if (!(await hasCompletePoolSnapshot(date, options.outputDir))) {
    throw new Error(`Pool snapshot is incomplete or has mismatched qdate: ${rel(path.join(ROOT, options.outputDir, date))}`);
  }
  stageLog("end", "resolve_date", { date, pool_summary: rel(poolSummaryPath) });
  const poolDir = path.join(ROOT, options.outputDir, date);
  const runId = options.runId ?? runIdFor(date, options.period);
  const runDir = path.join(DEFAULT_RUNS_DIR, runId);
  const jobMode = options.jobMode ?? "single";
  const plannedJobId = jobMode === "batch" ? dailyJobIdForOptions(options, date) : null;

  let codesResult;
  let inputDir = poolDir;
  let universeSummary = null;
  codesResult = await withStage("market_universe", {
    date,
    universe: options.universe,
    market: options.market,
    force_universe: Boolean(options.forceUniverse),
    job_id: plannedJobId,
  }, async () => {
    if (options.universe === "pool") {
      return runNodeAllowFailure("utils/parse_pool_json.js", [rel(poolDir), "--codes-only"], { streamOutput });
    }

    const sharedUniverseDir = rootPath(options.universeDir);
    const privateUniverseRoot = marketUniverseRootForRun({
      date,
      jobId: plannedJobId,
      jobMode,
      period: options.period,
      runId,
    }, {
      jobsDir: DEFAULT_JOBS_DIR,
      runsDir: DEFAULT_RUNS_DIR,
    });
    inputDir = path.join(privateUniverseRoot, date);
    const completePrivateUniverse = await hasCompleteMarketUniverse(date, privateUniverseRoot, options.market);
    const completeSharedUniverse = await hasCompleteMarketUniverse(date, sharedUniverseDir, options.market);
    stageLog("progress", "market_universe_cache", {
      input_dir: rel(inputDir),
      private_complete: completePrivateUniverse,
      shared_complete: completeSharedUniverse,
    });

    if (shouldReuseMarketUniverse({ complete: completePrivateUniverse, forceUniverse: options.forceUniverse })) {
      return {
        stdout: `Using existing private market universe: ${rel(inputDir)}\n`,
        stderr: "",
        exitCode: 0,
      };
    }
    if (shouldReuseMarketUniverse({ complete: completeSharedUniverse, forceUniverse: options.forceUniverse })) {
      await copyMarketUniverseSnapshot(date, sharedUniverseDir, privateUniverseRoot);
      return {
        stdout: `Copied market universe: ${rel(path.join(sharedUniverseDir, date))} -> ${rel(inputDir)}\n`,
        stderr: "",
        exitCode: 0,
      };
    } else {
      return runNodeAllowFailure("fetch/fetch_market_stocks.js", [
        "--date",
        date,
        "--market",
        options.market,
        "--output-dir",
        rel(privateUniverseRoot),
      ], { streamOutput });
    }
  });
  universeSummary = options.universe === "market"
    ? await readJson(path.join(inputDir, "summary.json"), null).catch(() => null)
    : null;
  writeProcessResult(codesResult);
  stageLog("end", "market_universe_result", {
    exit_code: codesResult.exitCode,
    input_dir: rel(inputDir),
    total_codes: universeSummary?.total_codes ?? null,
  });

  const freshnessContext = await withStage("freshness_context", {
    date,
    period: options.period,
    input_dir: rel(inputDir),
  }, () => buildKlineFreshnessContext({
    date,
    inputDir,
    options,
    runDir,
  }));
  if (freshnessContext?.expectedLatestDate && freshnessContext.codesPath) {
    options.expectedLatestDate = freshnessContext.expectedLatestDate;
    options.freshnessCodes = rel(freshnessContext.codesPath);
  }
  stageLog("end", "freshness_context_result", {
    expected_latest_date: freshnessContext?.expectedLatestDate ?? null,
    freshness_codes: freshnessContext?.codes?.size ?? null,
    freshness_source: freshnessContext?.source ?? null,
    freshness_codes_path: freshnessContext?.codesPath ? rel(freshnessContext.codesPath) : null,
  });
  const staleCodes = await withStage("stale_scan", {
    expected_latest_date: freshnessContext?.expectedLatestDate ?? null,
    period: options.period,
  }, () => findStaleKlineCodes({
    expectedLatestDate: freshnessContext?.expectedLatestDate ?? null,
    freshnessCodes: freshnessContext?.codes ?? null,
    period: options.period,
  }));
  stageLog("end", "stale_scan_result", { stale_codes: staleCodes.length });
  const jobContext = await withStage("prepare_job_progress", {
    date,
    period: options.period,
    job_mode: options.jobMode ?? "single",
    job_id: plannedJobId,
    stale_codes: staleCodes.length,
  }, () => prepareDailyJobProgress(options, {
    date,
    inputDir,
    preselectFailedCodes: staleCodes,
  }));
  let progress = jobContext?.progress ?? null;
  stageLog("end", "prepare_job_progress_result", {
    job_id: jobContext?.jobId ?? null,
    chain_depth: jobContext?.chainDepth ?? null,
    max_chain_depth: progress?.max_chain_depth ?? null,
    batch_size: progress?.batch_size ?? null,
    batch_codes: jobContext?.selection.codes.length ?? null,
    batch_source: jobContext?.selection.source ?? null,
    progress_counts: progress?.counts ?? null,
    progress_file: jobContext ? rel(jobContext.progressPath) : null,
  });
  const cleanupSummary = await withStage("cleanup_invalid_kline", {
    period: options.period,
  }, () => cleanupInvalidKlineFiles(options.period));
  if (cleanupSummary.removed_codes.length > 0) {
    console.error(
      `Removed ${cleanupSummary.removed_codes.length} invalid ${options.period} kline file(s) before sync.`
    );
    if (jobContext) {
      progress = markProgressCodesFailed(progress, cleanupSummary.removed_codes);
      await writeJson(jobContext.progressPath, progress);
    }
  }
  stageLog("end", "cleanup_invalid_kline_result", {
    removed_codes: cleanupSummary.removed_codes.length,
  });
  const klineInputPath = jobContext ? jobContext.batchCodesPath : inputDir;
  const klineOptions = jobContext
    ? { ...options, batchSize: null, limit: null, offset: null }
    : options;
  const klineArgs = [rel(klineInputPath), "--period", options.period, "--engine", options.engine];
  appendKlineSyncOptions(klineArgs, klineOptions, { includeOutputDir: false });
  const klineResult = await withStage("kline_sync", {
    period: options.period,
    engine: options.engine,
    kline_input: rel(klineInputPath),
    expected_latest_date: options.expectedLatestDate ?? null,
    freshness_codes: options.freshnessCodes ?? null,
    concurrency: options.concurrency,
    retry_attempts: options.retryAttempts ?? null,
  }, () => runNodeAllowFailure("fetch/query_pool_klines.js", klineArgs, { streamOutput }));
  writeProcessResult(klineResult);
  stageLog("end", "kline_sync_result", {
    exit_code: klineResult.exitCode,
    stdout_bytes: klineResult.stdout.length,
    stderr_bytes: klineResult.stderr.length,
  });

  const defaultSummaryPath = path.join(DEFAULT_KLINE_DIR, options.period, `summary.${options.period}.json`);
  const emittedSummaryPath = parseKlineSummaryPath(klineResult.stdout, options.period);
  const summaryPath = emittedSummaryPath ?? defaultSummaryPath;
  const emptyKlineSummary = {
    period: options.period,
    total_codes: 0,
    success: 0,
    migrated_existing: 0,
    skipped_existing: 0,
    failed: 0,
    files: {},
  };
  const klineSummary = emittedSummaryPath
    ? await readJson(summaryPath, emptyKlineSummary)
    : emptyKlineSummary;
  stageLog("end", "kline_summary_read", {
    summary_path: rel(summaryPath),
    emitted_summary: Boolean(emittedSummaryPath),
    total_codes: klineSummary.total_codes ?? null,
    success: klineSummary.success ?? null,
    failed: klineSummary.failed ?? null,
    skipped_existing: klineSummary.skipped_existing ?? null,
    status: klineSummary.status ?? null,
  });

  if (jobContext) {
    progress = await withStage("apply_progress", {
      job_id: jobContext.jobId,
      chain_depth: jobContext.chainDepth,
      progress_file: rel(jobContext.progressPath),
    }, async () => applyProgressResults(progress, klineSummary, {
      chainDepth: jobContext.chainDepth,
    }));
    await writeJson(jobContext.progressPath, progress);
    stageLog("end", "apply_progress_result", {
      job_id: jobContext.jobId,
      status: progress.status,
      counts: progress.counts,
    });
  }

  const validateResult = await withStage("validate_kline", {
    period: options.period,
  }, () => runNodeAllowFailure("fetch/check_kline_empty.js", [
    "data/kline",
    "--period",
    options.period,
    "--json",
  ], { streamOutput }));
  const quality = await buildQuality(runId, validateResult, options.period);
  stageLog("end", "validate_kline_result", {
    exit_code: validateResult.exitCode,
    quality_status: quality.status,
    issue_count: quality.issue_count ?? null,
  });
  const failures = {
    run_id: runId,
    failed: 0,
    items: extractKlineFailures(klineSummary, options.period),
  };
  failures.failed = failures.items.length;

  const klineFailed = Number(klineSummary.failed ?? 0);
  const unexpectedKlineFailure = klineResult.exitCode !== 0 && klineFailed === 0;
  const klineFailureReasons = Array.isArray(klineSummary.failure_reasons) ? klineSummary.failure_reasons : [];
  const hardKlineReasons = jobContext
    ? ["aws_success_zero"]
    : ["success_rate_below_minimum", "aws_success_zero"];
  const hardKlineFailure = klineFailureReasons.some((reason) =>
    hardKlineReasons.includes(reason)
  );
  const progressBlocked = progress?.status === "blocked";
  const hardFailed =
    poolResult.exitCode !== 0 ||
    codesResult.exitCode !== 0 ||
    quality.status === "failed" ||
    unexpectedKlineFailure ||
    hardKlineFailure ||
    progressBlocked;
  const failed =
    klineFailed +
    (poolResult.exitCode === 0 ? 0 : 1) +
    (codesResult.exitCode === 0 ? 0 : 1);
  const success = Number(klineSummary.success ?? 0) + Number(klineSummary.migrated_existing ?? 0);
  const skipped = Number(klineSummary.skipped_existing ?? 0);
  const total = Number(klineSummary.total_codes ?? success + skipped + Number(klineSummary.failed ?? 0));
  const status =
    hardFailed || failed > 0 || quality.status === "failed"
      ? "completed_with_failures"
      : "completed";
  const shouldDispatchNext =
    Boolean(jobContext) &&
    progress?.status === "running" &&
    !hardFailed &&
    jobContext.chainDepth < progress.max_chain_depth;

  const run = {
    run_id: runId,
    type: "daily",
    date,
    period: options.period,
    engine: options.engine,
    aws_region: options.awsRegion ?? null,
    huaweicloud_region: options.huaweicloudRegion ?? null,
    lambda_name: options.lambdaName ?? null,
    config: options.config ?? null,
    concurrency: options.concurrency ?? null,
    retry_attempts: options.retryAttempts ?? null,
    retry_concurrency: options.retryConcurrency ?? null,
    min_success_rate: options.minSuccessRate ?? null,
    force: Boolean(options.force),
    universe: options.universe,
    market: options.universe === "market" ? options.market : null,
    universe_total_codes: universeSummary?.total_codes ?? null,
    input: rel(path.join(inputDir, "codes.json")),
    kline_input: rel(klineInputPath),
    status,
    total,
    success,
    skipped,
    failed,
    batch_size: jobContext ? progress.batch_size : (klineSummary.batch_size ?? null),
    selection_mode: klineSummary.selection_mode ?? null,
    job_mode: jobContext ? "batch" : (options.jobMode ?? "single"),
    job_id: jobContext?.jobId ?? null,
    job_status: progress?.status ?? null,
    chain_depth: progress?.chain_depth ?? null,
    max_chain_depth: progress?.max_chain_depth ?? null,
    should_dispatch_next: shouldDispatchNext,
    progress_counts: progress?.counts ?? null,
    progress_file: jobContext ? rel(jobContext.progressPath) : null,
    progress_batch_source: jobContext?.selection.source ?? null,
    progress_batch_codes: jobContext?.selection.codes.length ?? null,
    initial_failed: klineSummary.initial_failed ?? 0,
    retried: klineSummary.retried ?? 0,
    retry_success: klineSummary.retry_success ?? 0,
    retry_failed: klineSummary.retry_failed ?? 0,
    kline_success_rate: klineSummary.success_rate ?? null,
    kline_engine_counts: klineSummary.engine_counts ?? {},
    kline_failure_reason_counts: klineSummary.failure_reason_counts ?? {},
    kline_region_counts: klineSummary.region_counts ?? {},
    kline_failure_reasons: klineFailureReasons,
    expected_latest_date: freshnessContext?.expectedLatestDate ?? null,
    freshness_codes: freshnessContext?.codes.size ?? null,
    freshness_source: freshnessContext?.source ?? null,
    stale_completed: staleCodes.length,
    started_at: startedAt,
    finished_at: isoNow(),
    artifacts: {
      pool_dir: rel(poolDir),
      universe_dir: options.universe === "market" ? rel(inputDir) : null,
      job_progress: jobContext ? rel(jobContext.progressPath) : null,
      job_batch_codes: jobContext ? rel(jobContext.batchCodesPath) : null,
      kline_dir: rel(path.join(DEFAULT_KLINE_DIR, options.period)),
      kline_summary: rel(summaryPath),
      freshness_codes: freshnessContext?.codesPath ? rel(freshnessContext.codesPath) : null,
      run: rel(path.join(runDir, "run.json")),
      failures: rel(path.join(runDir, "failures.json")),
      quality: rel(path.join(runDir, "quality.json")),
    },
    commands: {
      pool_exit_code: poolResult.exitCode,
      codes_exit_code: codesResult.exitCode,
      universe_exit_code: options.universe === "market" ? codesResult.exitCode : null,
      kline_exit_code: klineResult.exitCode,
      quality_exit_code: validateResult.exitCode,
    },
  };

  await withStage("write_run_artifacts", {
    run_id: runId,
    run_dir: rel(runDir),
  }, async () => {
    await writeJson(path.join(runDir, "failures.json"), failures);
    await writeJson(path.join(runDir, "quality.json"), quality);
    await writeJson(path.join(runDir, "run.json"), run);
  });
  console.log(rel(path.join(runDir, "run.json")));
  printDailyRunSummary(run, quality, failures);

  if (options.commit) {
    await withStage("commit_data", {
      run_id: runId,
      status: run.status,
      job_status: run.job_status,
      should_dispatch_next: run.should_dispatch_next,
    }, () => commitData(runId));
  }

  stageLog("end", "daily_end", {
    run_id: runId,
    date,
    period: options.period,
    status: run.status,
    job_status: run.job_status,
    should_dispatch_next: run.should_dispatch_next,
  });
  if (run.status !== "completed" && options.allowPartial && !hardFailed) {
    console.error("Daily run completed with partial kline failures; --allow-partial enabled.");
  } else if (run.status !== "completed") {
    process.exitCode = 1;
  }
}

async function hasCompletePoolSnapshot(date, outputDir) {
  const poolDir = path.join(ROOT, outputDir, date);
  for (const pool of ["dt", "qs", "zb", "zt"]) {
    try {
      const payload = JSON.parse(await fs.readFile(path.join(poolDir, `${pool}.json`), "utf8"));
      if (String(payload?.data?.qdate ?? "") !== date) {
        return false;
      }
      if (!Array.isArray(payload?.data?.pool)) {
        return false;
      }
    } catch {
      return false;
    }
  }
  return true;
}

async function commandRun(argv) {
  const subcommand = argv[0];
  if (subcommand === "list") {
    const entries = await fs.readdir(DEFAULT_RUNS_DIR, { withFileTypes: true }).catch(() => []);
    for (const entry of entries.filter((item) => item.isDirectory()).map((item) => item.name).sort()) {
      console.log(entry);
    }
    return;
  }

  const runId = argv[1];
  if (!runId) {
    throw new Error(`run ${subcommand ?? ""} requires <run_id>`);
  }

  const fileName = subcommand === "failures" ? "failures.json" : "run.json";
  const filePath = path.join(DEFAULT_RUNS_DIR, runId, fileName);
  process.stdout.write(await fs.readFile(filePath, "utf8"));
}

async function readExistingJson(filePath) {
  try {
    return JSON.parse(await fs.readFile(filePath, "utf8"));
  } catch {
    return null;
  }
}

async function commandReport(argv) {
  const subcommand = argv[0];
  if (subcommand !== "daily") {
    throw new Error(`Unknown report command: ${subcommand ?? ""}`);
  }

  const options = parseOptions(argv.slice(1));
  if (!options.date) {
    throw new Error("report daily requires --date <YYYYMMDD>");
  }

  const date = normalizeDate(options.date);
  const report = await generateDailyReport({
    date,
    klineDir: DEFAULT_KLINE_DIR,
    outputDir: path.join(ROOT, "reports"),
    poolDir: DEFAULT_POOL_DIR,
  });
  console.log(rel(report.reportDir));
}

function printJson(payload) {
  process.stdout.write(`${JSON.stringify(payload, null, 2)}\n`);
}

async function commandDb(argv) {
  const subcommand = argv[0];
  const options = parseOptions(argv.slice(1), {
    db: "db/stocks.db",
    schema: "db/database_schema.sql",
  });
  const { initDatabase, queryDatabase } = require("./../src/db/sqlite");

  if (subcommand === "init") {
    printJson(initDatabase({ dbFile: options.db, schemaFile: options.schema }));
    return;
  }

  if (subcommand === "query") {
    if (!options.sql) {
      throw new Error("db query requires --sql <sql>");
    }
    printJson(queryDatabase({ dbFile: options.db, sql: options.sql }));
    return;
  }

  throw new Error(`Unknown db command: ${subcommand ?? ""}`);
}

async function commandStats(argv) {
  const subcommand = argv[0];
  const options = parseOptions(argv.slice(1), { db: "mydb.db" });
  const { analyzeNewHighs, yearlyPositivePct } = require("./../src/stats/statistics");

  if (subcommand === "yearly-positive") {
    if (!options.metricColumn) {
      throw new Error("stats yearly-positive requires --metric-column <column>");
    }
    printJson(yearlyPositivePct({
      dbFile: options.db,
      metricColumn: options.metricColumn,
      stockCode: options.stockCode ?? null,
    }));
    return;
  }

  if (subcommand === "new-highs") {
    printJson(analyzeNewHighs({
      dbFile: options.db,
      year: options.year ?? null,
      date: options.date ?? null,
    }));
    return;
  }

  throw new Error(`Unknown stats command: ${subcommand ?? ""}`);
}

async function commandProxy(argv) {
  const subcommand = argv[0];
  const options = parseOptions(argv.slice(1));
  const { checkEastmoneyAccess, listProxies, rotateProxy } = require("./../src/proxy/clash");
  const common = {
    configFile: options.config,
    groupName: options.group,
  };

  if (subcommand === "list") {
    printJson(await listProxies(common));
    return;
  }

  if (subcommand === "rotate") {
    printJson(await rotateProxy({ ...common, proxyName: options.proxy ?? null }));
    return;
  }

  if (subcommand === "check") {
    printJson(await checkEastmoneyAccess());
    return;
  }

  throw new Error(`Unknown proxy command: ${subcommand ?? ""}`);
}

async function existingDataPathspecs(candidates = ["data", "runs", "reports"]) {
  return existingPathspecs(ROOT, candidates);
}

function printDailyRunSummary(run, quality, failures) {
  const qualityStatus = quality?.status ?? "recorded";
  console.log(
    [
      `Daily run ${run.run_id}: ${run.status}`,
      `total=${run.total}`,
      `success=${run.success}`,
      `failed=${run.failed}`,
      `skipped=${run.skipped}`,
      `universe=${run.universe ?? "pool"}`,
      `universe_total_codes=${run.universe_total_codes ?? "n/a"}`,
      `batch_size=${run.batch_size ?? "n/a"}`,
      `selection_mode=${run.selection_mode ?? "n/a"}`,
      `job_mode=${run.job_mode ?? "single"}`,
      `job_status=${run.job_status ?? "n/a"}`,
      `progress_counts=${JSON.stringify(run.progress_counts ?? {})}`,
      `dispatch_next=${run.should_dispatch_next ?? false}`,
      `initial_failed=${run.initial_failed ?? 0}`,
      `retried=${run.retried ?? 0}`,
      `retry_success=${run.retry_success ?? 0}`,
      `retry_failed=${run.retry_failed ?? 0}`,
      `success_rate=${run.kline_success_rate ?? "n/a"}`,
      `engine_counts=${JSON.stringify(run.kline_engine_counts ?? {})}`,
      `failure_reason_counts=${JSON.stringify(run.kline_failure_reason_counts ?? {})}`,
      `region_counts=${JSON.stringify(run.kline_region_counts ?? {})}`,
      `quality=${qualityStatus}`,
    ].join(" ")
  );

  for (const item of failures.items.slice(0, 5)) {
    console.error(
      `Kline failure ${item.code ?? "unknown"}: ${item.reason ?? item.error ?? item.status ?? "unknown"}`
    );
  }

  if (quality?.status === "failed") {
    for (const issue of (quality.issues ?? []).slice(0, 5)) {
      console.error(`Quality issue ${issue.code ?? "unknown"}: ${issue.issue ?? "unknown"}`);
    }
  }
}

async function commitData(runId) {
  const runPath = path.join(DEFAULT_RUNS_DIR, runId, "run.json");
  const qualityPath = path.join(DEFAULT_RUNS_DIR, runId, "quality.json");
  const run = await readJson(runPath);
  const quality = await readJson(qualityPath, { status: "recorded" });
  const pathspec = await existingDataPathspecs(dataCommitPathspecs(run));

  if (pathspec.length === 0) {
    console.log("No data paths to commit.");
    return;
  }

  await execFileAsync("git", ["add", "--", ...pathspec], { cwd: ROOT });
  const files = await stagedFiles(ROOT, pathspec);
  if (files.length === 0) {
    console.log("No data changes to commit.");
    return;
  }

  const message = dataCommitMessage(run, quality);
  await execFileAsync(
    "git",
    ["commit", "-m", message.title, "-m", message.body, "--", ...files],
    { cwd: ROOT, maxBuffer: 20 * 1024 * 1024 }
  );
}

async function commandGit(argv) {
  const subcommand = argv[0];
  if (subcommand === "status-data") {
    const pathspec = await existingDataPathspecs();
    const { stdout } = await execFileAsync("git", ["status", "--short", "--", ...pathspec], {
      cwd: ROOT,
    });
    process.stdout.write(stdout);
    return;
  }

  if (subcommand === "commit-data") {
    const options = parseOptions(argv.slice(1));
    if (!options.runId) {
      throw new Error("git commit-data requires --run-id <run_id>");
    }
    await commitData(options.runId);
    return;
  }

  throw new Error(`Unknown git command: ${subcommand ?? ""}`);
}

async function main() {
  const [command, subcommand, ...rest] = process.argv.slice(2);

  if (!command || command === "--help" || command === "-h") {
    printUsage();
    return;
  }

  if (command === "doctor") {
    await commandDoctor();
    return;
  }
  if (command === "pool" && subcommand === "pull") {
    await commandPoolPull(rest);
    return;
  }
  if (command === "stocks") {
    await commandStocks([subcommand, ...rest]);
    return;
  }
  if (command === "codes" && subcommand === "build") {
    await commandCodesBuild(rest);
    return;
  }
  if (command === "kline" && subcommand === "sync") {
    await commandKlineSync(rest);
    return;
  }
  if (command === "kline" && subcommand === "retry") {
    await commandKlineRetry(rest);
    return;
  }
  if (command === "kline" && subcommand === "fetch") {
    await commandKlineFetch(rest);
    return;
  }
  if (command === "kline" && subcommand === "validate") {
    await commandKlineValidate(rest);
    return;
  }
  if (command === "daily") {
    await commandDaily([subcommand, ...rest].filter(Boolean));
    return;
  }
  if (command === "run") {
    await commandRun([subcommand, ...rest]);
    return;
  }
  if (command === "report") {
    await commandReport([subcommand, ...rest]);
    return;
  }
  if (command === "db") {
    await commandDb([subcommand, ...rest]);
    return;
  }
  if (command === "stats") {
    await commandStats([subcommand, ...rest]);
    return;
  }
  if (command === "aws") {
    await commandAws([subcommand, ...rest]);
    return;
  }
  if (command === "proxy") {
    await commandProxy([subcommand, ...rest]);
    return;
  }
  if (command === "git") {
    await commandGit([subcommand, ...rest]);
    return;
  }

  throw new Error(`Unknown command: ${command}`);
}

main().catch((error) => {
  console.error(error.message);
  process.exit(1);
});
